{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/scripts/hooks/post-tool-use.js\""
          }
        ],
        "description": "Remind the agent to update Run Trace after writes",
        "id": "plan-write-reminder"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/scripts/hooks/stop.js\""
          }
        ],
        "description": "Check active plan completeness before stop",
        "id": "plan-stop-check"
      }
    ]
  }
}
